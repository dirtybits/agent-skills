{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ethereum-development invocation schema",
  "type": "object",
  "properties": {
    "topic": {
      "type": "string",
      "enum": [
        "architecture",
        "solidity",
        "evm",
        "gas",
        "transactions",
        "clients",
        "testing",
        "security",
        "deployment",
        "frontend",
        "indexing",
        "debugging",
        "incident-response"
      ]
    },
    "network": {
      "type": "string",
      "enum": ["local", "mainnet", "sepolia", "holesky", "hoodi", "base", "optimism", "arbitrum", "polygon", "bsc", "avalanche", "gnosis", "custom"]
    },
    "stack": {
      "type": "string",
      "enum": ["foundry", "hardhat", "mixed", "frontend", "backend", "indexer", "unknown"]
    },
    "public_broadcast_approved": {
      "type": "boolean",
      "default": false,
      "description": "Must be true only after explicit user approval for public-network transactions."
    }
  },
  "additionalProperties": true
}
